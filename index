<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">

  <!-- 1. Title -->
  <title>Your Name – Resume</title>

  <!-- 7. Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&family=Inter&display=swap" rel="stylesheet">

  <!-- 9. Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- 8. Styles -->
  <style>
    body {
      font-family: 'Inter', sans-serif;
      background-color: #f8f9fa;
    }

    h1, h2 {
      font-family: 'Playfair Display', serif;
      color: #2c3e50;
    }

    .resume {
      background: white;
      padding: 2rem;
      border-radius: 10px;
      box-shadow: 0 0 15px rgba(0,0,0,0.1);
    }

    img {
      max-width: 100%;
      border-radius: 10px;
    }
  </style>
</head>

<body>
  <!-- 9. Bootstrap container -->
  <div class="container my-5">

    <!-- 12. Two-column grid -->
    <div class="row justify-content-center">
      <div class="col-md-10 resume">
        <div class="row">

          <!-- Left column -->
          <div class="col-md-4 text-center">
            <!-- 11. Image -->
            <img src="your-image.jpg" alt="Artwork or photo">

            <p class="mt-3">
              <!-- 6. Email link -->
              <a href="mailto:youremail@utdallas.edu">youremail@utdallas.edu</a>
            </p>
          </div>

          <!-- Right column -->
          <div class="col-md-8">

            <!-- 2. First-level heading -->
            <h1>Your Name</h1>

            <!-- 3. Paragraph -->
            <p>
              I am a creative individual with a strong interest in art, design, and digital media.
              I enjoy using visual storytelling and technology to express ideas and solve problems.
            </p>

            <!-- 4. Education -->
            <h2>Education</h2>
            <!-- 5. List -->
            <ul>
              <li>University of Texas at Dallas</li>
              <li>Community College Name</li>
            </ul>

            <!-- Employment -->
            <h2>Employment</h2>
            <ul>
              <li>Job Title – Company Name</li>
              <li>Freelance Artist / Designer</li>
            </ul>

            <!-- Skills -->
            <h2>Skills</h2>
            <ul>
              <li>Adobe Photoshop</li>
              <li>Illustration & Drawing</li>
              <li>HTML & CSS</li>
            </ul>

            <!-- Awards / Clubs -->
            <h2>Awards & Clubs</h2>
            <ul>
              <li>Art Club Member</li>
              <li>Student Exhibition Participant</li>
            </ul>

            <!-- 6. Regular link -->
            <p>
              Portfolio: 
              <a href="https://yourportfolio.com" target="_blank">yourportfolio.com</a>
            </p>

          </div>
        </div>
      </div>
    </div>

  </div>
</body>
</html>
